public class Hero {
    public String name;
    public Hero(String name){
        this.name = name;
    }
    public void fight(){
        System.out.println("Let's fight");
    }
}

public class Superhero extends Hero {
    public Superhero(String name) {
        super(name);
    }
    public void fly() {
        System.out.println("Let's fly!");
    }
}

public class Main{
public static void main(String[] args) {
    Hero hero1 = new Hero("Maximus");  
    Hero hero2 = new Superhero("Superman"); 
    hero1.fight(); 
    hero2.fight(); 
    hero2.fly();

}
}


